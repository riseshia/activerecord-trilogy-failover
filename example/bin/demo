#!/usr/bin/env ruby
# frozen_string_literal: true

ENV["RAILS_ENV"] ||= "development"

require_relative "../config/application"
Rails.application.initialize!
require_relative "../app/models/application_record"
require_relative "../app/models/post"

puts "=" * 60
puts "activerecord-trilogy-failover Demo"
puts "=" * 60
puts

# 1. Verify the patch is loaded via Railtie
adapter_class = ActiveRecord::ConnectionAdapters::TrilogyAdapter
if adapter_class.ancestors.include?(ActiveRecordTrilogyFailover::AdapterPatch)
  puts "[OK] AdapterPatch is loaded via Railtie"
else
  puts "[FAIL] AdapterPatch not found in TrilogyAdapter ancestors"
  exit 1
end

# 2. Connect as app user (no SUPER privilege)
ActiveRecord::Base.establish_connection(:development)

# 3. Normal operations
Post.delete_all
Post.create!(title: "Hello from failover example")
puts "[OK] INSERT succeeded (read_only = OFF)"

post = Post.first
puts "[OK] SELECT succeeded: #{post.title}"

# 4. Open admin connection for toggling read_only
admin = Trilogy.new(
  host: "127.0.0.1",
  port: 3307,
  username: "admin",
  password: "admin",
  database: "failover_example"
)

puts
puts "-" * 60
puts "Scenario 1: Error detection (read_only → ConnectionFailed)"
puts "-" * 60
puts

admin.query("SET GLOBAL read_only = 1")
puts "[INFO] SET GLOBAL read_only = 1"

# SELECT still works
post = Post.first
puts "[OK] SELECT still works under read_only"

# INSERT → ConnectionFailed
begin
  Post.create!(title: "This should fail")
  puts "[UNEXPECTED] INSERT succeeded under read_only"
rescue ActiveRecord::ConnectionFailed => e
  puts "[OK] INSERT raised ActiveRecord::ConnectionFailed"
  puts "     #{e.message.lines.first.strip}"
ensure
  admin.query("SET GLOBAL read_only = 0")
  puts "[INFO] SET GLOBAL read_only = 0 (restored)"
end

puts
puts "-" * 60
puts "Scenario 2: Connection discarded after failure, fresh connection on next query"
puts "-" * 60
puts

# Record connection ID before failure
conn_id_before = ActiveRecord::Base.lease_connection.raw_connection.query("SELECT CONNECTION_ID() AS id").first
puts "[INFO] Connection ID before failure: #{conn_id_before}"

admin.query("SET GLOBAL read_only = 1")
puts "[INFO] SET GLOBAL read_only = 1"

begin
  Post.create!(title: "This should fail")
  puts "[UNEXPECTED] INSERT succeeded under read_only"
rescue ActiveRecord::ConnectionFailed => e
  puts "[OK] INSERT raised ConnectionFailed (connection should be discarded)"
end

admin.query("SET GLOBAL read_only = 0")
puts "[INFO] SET GLOBAL read_only = 0 (simulating failover complete)"

# Next query should succeed on a fresh connection
post = Post.create!(title: "Written on fresh connection!")
conn_id_after = ActiveRecord::Base.lease_connection.raw_connection.query("SELECT CONNECTION_ID() AS id").first
puts "[OK] Next INSERT succeeded: #{post.title}"
puts "[INFO] Connection ID after recovery: #{conn_id_after}"

if conn_id_before != conn_id_after
  puts "[OK] Connection was discarded and replaced (#{conn_id_before} → #{conn_id_after})"
else
  puts "[WARN] Same connection ID — connection may not have been discarded"
end

# 5. Cleanup
admin.close
Post.delete_all

puts
puts "=" * 60
puts "Demo complete!"
puts "=" * 60
